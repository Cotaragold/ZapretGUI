<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:System="clr-namespace:System;assembly=mscorlib">

    <!-- Базовые цвета -->
    <Color x:Key="ColorBackgroundStart">#FF060714</Color>
    <Color x:Key="ColorBackgroundEnd">#FF050510</Color>
    <Color x:Key="ColorCardBackground">#FF101023</Color>
    <Color x:Key="ColorCardBorder">#FF242445</Color>

    <Color x:Key="ColorAccentCyan">#FF00FFFF</Color>
    <Color x:Key="ColorAccentPurple">#FFC350FF</Color>
    <Color x:Key="ColorAccentDanger">#FFFF3B6A</Color>
    <Color x:Key="ColorAccentSuccess">#FF47FF9C</Color>

    <Color x:Key="ColorTextPrimary">#FFF5F7FF</Color>
    <Color x:Key="ColorTextSecondary">#FF9FA4C8</Color>

    <LinearGradientBrush x:Key="AppBackgroundGradientBrush"
                         StartPoint="0,0"
                         EndPoint="1,1">
        <GradientStop Color="{StaticResource ColorBackgroundStart}" Offset="0" />
        <GradientStop Color="{StaticResource ColorBackgroundEnd}" Offset="1" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="CardBackgroundBrush"
                     Color="{StaticResource ColorCardBackground}" />
    <SolidColorBrush x:Key="CardBorderBrush"
                     Color="{StaticResource ColorCardBorder}" />

    <SolidColorBrush x:Key="AccentCyanBrush"
                     Color="{StaticResource ColorAccentCyan}" />
    <SolidColorBrush x:Key="AccentPurpleBrush"
                     Color="{StaticResource ColorAccentPurple}" />
    <SolidColorBrush x:Key="AccentDangerBrush"
                     Color="{StaticResource ColorAccentDanger}" />
    <SolidColorBrush x:Key="AccentSuccessBrush"
                     Color="{StaticResource ColorAccentSuccess}" />

    <SolidColorBrush x:Key="TextPrimaryBrush"
                     Color="{StaticResource ColorTextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush"
                     Color="{StaticResource ColorTextSecondary}" />

    <SolidColorBrush x:Key="HeaderBackgroundBrush"
                     Color="#FF050614" />

    <SolidColorBrush x:Key="InputBackgroundBrush"
                     Color="#FF15152A" />

    <SolidColorBrush x:Key="ItemBackgroundBrush"
                     Color="#FF17172D" />
    <SolidColorBrush x:Key="ItemBorderBrush"
                     Color="#FF2A2A4A" />

    <!-- Общие размеры -->
    <CornerRadius x:Key="CornerRadiusSmall">4</CornerRadius>
    <CornerRadius x:Key="CornerRadiusMedium">8</CornerRadius>
    <CornerRadius x:Key="CornerRadiusLarge">12</CornerRadius>

    <Thickness x:Key="SpacingSmall">4</Thickness>
    <Thickness x:Key="SpacingMedium">8</Thickness>
    <Thickness x:Key="SpacingLarge">12</Thickness>

    <System:Double x:Key="FontSizeSmall">11</System:Double>
    <System:Double x:Key="FontSizeMedium">13</System:Double>
    <System:Double x:Key="FontSizeLarge">16</System:Double>

    <SolidColorBrush x:Key="TransparentBrush" Color="#00FFFFFF" />

    <!-- Динамические ресурсы для стилей (WPF нужны явно определённые ключи) -->
    <Color x:Key="NeonCyan">#FF00FFFF</Color>
    <Color x:Key="NeonPurple">#FFC350FF</Color>
    <Color x:Key="Bg0">#FF060714</Color>
    <Color x:Key="Bg1">#FF101023</Color>
    <Color x:Key="TextPrimary">#FFF5F7FF</Color>
    <Color x:Key="TextMuted">#FF9FA4C8</Color>
    <Color x:Key="BorderNeon">#FF3D3D7D</Color>

</ResourceDictionary>

